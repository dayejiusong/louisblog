msgid "Passwords do not match."
msgstr "两次输入的密码不一致。"

msgid "Email is incorrect, please us a normal email format."
msgstr "邮箱格式不正确，请使用正常的邮箱格式。"

msgid "Password reset is not available on this server."
msgstr "当前服务器不支持密码重置。"

msgid "If this email is registered, a reset code has been sent. Check your inbox."
msgstr "如果该邮箱已注册，重置码已发送，请查收邮箱。"

msgid "Invalid or expired reset code."
msgstr "重置码无效或已过期。"

msgid "Password updated successfully. You can now log in."
msgstr "密码更新成功，你现在可以登录了。"

msgid "Could not connect to the server (Error %d).\nPlease contact us via our [url=%s][color=#%s]Discord server[/color][/url].\nMeanwhile be sure to test the offline mode!"
msgstr "无法连接到服务器（错误 %d）。\n请通过我们的 [url=%s][color=#%s]Discord 服务器[/color][/url] 联系我们。\n同时也别忘了试试离线模式！"

