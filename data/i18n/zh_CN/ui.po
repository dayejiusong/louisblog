msgstr "账号名或密码无效。"

msgid "Password should only include alpha-numeric characters and symbols."
msgstr "密码只能包含字母、数字和符号。"

msgid "Password length should be inbetween %d and %d character long."
msgstr "密码长度必须在 %d 到 %d 个字符之间。"

