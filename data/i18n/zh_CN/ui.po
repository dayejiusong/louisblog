msgstr "角色信息不完整。"

msgid "Character name not available."
msgstr "角色名不可用。"

msgid "Unknown character issue (Error %d).\nPlease contact us via our [url=%s][color=#%s]Discord server[/color][/url].\n"
msgstr "发生未知角色错误（错误 %d）。\n请通过我们的 [url=%s][color=#%s]Discord 服务器[/color][/url] 联系我们。\n"

